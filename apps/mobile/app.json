{
  "expo": {
    "name": "Nearby",
    "slug": "nearby",
    "scheme": "nearby",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#2563EB"
    },
    "platforms": [
      "ios",
      "android"
    ],
    "newArchEnabled": true,
    "ios": {
      "bundleIdentifier": "com.citywallet.app",
      "supportsTablet": true,
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Nearby uses your location to show offers near you.",
        "NSCameraUsageDescription": "Merchants use the camera to scan customer QR codes."
      }
    },
    "android": {
      "package": "com.citywallet.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#2563EB"
      },
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "CAMERA",
        "VIBRATE",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "CAMERA",
        "VIBRATE",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Nearby uses your location to show offers near you."
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Nearby uses the camera to scan offer QR codes."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Nearby needs access to your photos to set a store or location cover image."
        }
      ],
      [
        "@stripe/stripe-react-native",
        {
          "merchantIdentifier": "merchant.com.citywallet.app",
          "enableGooglePay": true
        }
      ],
      "expo-secure-store"
    ],
    "extra": {
      "router": {
        "origin": false
      },
      "apiBaseUrl": "https://nearby-app-rust.vercel.app",
      "supabaseUrl": "https://kljabbvlkcnnnnslijfg.supabase.co",
      "supabaseAnonKey": "REPLACE_WITH_SUPABASE_ANON_KEY",
      "stripePublishableKey": "REPLACE_WITH_STRIPE_PUBLISHABLE_KEY",
      "googlePlacesApiKey": "REPLACE_WITH_GOOGLE_PLACES_API_KEY",
      "resendApiKey": "REPLACE_WITH_RESEND_API_KEY",
      "eas": {
        "projectId": "ad3990cd-6cab-4d3d-879c-eb09e4525bba"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/ad3990cd-6cab-4d3d-879c-eb09e4525bba"
    }
  }
}
